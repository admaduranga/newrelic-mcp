# Required: New Relic user API key (NerdGraph). Create at https://one.newrelic.com/nr1-core/api-keys
NEW_RELIC_API_KEY=

# Optional: Region for NerdGraph endpoint. One of: us, eu (default: us)
NEW_RELIC_REGION=us

# Optional: Default account ID when not passed to execute_nrql (convenience for single-account use)
NEW_RELIC_ACCOUNT_ID=
